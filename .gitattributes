# Normaliser les fins de ligne en LF dans le dépôt (Linux/Mac/Docker compatible)
* text=auto eol=lf

# Fichiers binaires — ne pas toucher aux fins de ligne
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.lock text eol=lf
