# ============================================================
#  Template des variables locales — Backend Symfony
#  Copiez ce fichier en .env.local pour surcharger les valeurs
#  de .env (développement local sans Docker, par exemple).
#  Ce fichier est commité dans le dépôt (pas de secrets).
# ============================================================

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_with_a_secure_random_string
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Décommentez et adaptez si vous n'utilisez pas Docker
# DATABASE_URL="mysql://ugo_user:change_me@127.0.0.1:3306/ugo_db?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> mysql ###
# Surcharge des credentials MySQL (si différents du .env)
# MYSQL_ROOT_PASSWORD=change_me
# MYSQL_DATABASE=ugo_db
# MYSQL_USER=ugo_user
# MYSQL_PASSWORD=change_me
# PMA_USER=ugo_user
# PMA_PASSWORD=change_me
# PMA_DATABASE=ugo_db
###< mysql ###

